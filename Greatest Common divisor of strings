#include <stdio.h>
#include <string.h>
#include <stdlib.h>

/* Function to compute GCD of two numbers */
int gcd(int a, int b) {
    while (b != 0) {
        int temp = b;
        b = a % b;
        a = temp;
    }
    return a;
}

/* Function to find GCD of strings */
char* gcdOfStrings(char* str1, char* str2) {
    int len1 = strlen(str1);
    int len2 = strlen(str2);

    /* Allocate memory for concatenations */
    char *concat1 = malloc(len1 + len2 + 1);
    char *concat2 = malloc(len1 + len2 + 1);

    /* Create concatenated strings */
    strcpy(concat1, str1);
    strcat(concat1, str2);

    strcpy(concat2, str2);
    strcat(concat2, str1);

    /* Check if concatenations are equal */
    if (strcmp(concat1, concat2) != 0) {
        free(concat1);
        free(concat2);
        return strdup("");   // return empty string
    }

    /* Find GCD of lengths */
    int g = gcd(len1, len2);

    /* Allocate result string */
    char *result = malloc(g + 1);

    /* Copy first g characters */
    strncpy(result, str1, g);
    result[g] = '\0';

    free(concat1);
    free(concat2);

    return result;
}

/* Test driver */
int main() {
    char str1[] = "ABABAB";
    char str2[] = "ABAB";

    char *answer = gcdOfStrings(str1, str2);

    printf("GCD String: %s\n", answer);

    free(answer);
    return 0;
}
